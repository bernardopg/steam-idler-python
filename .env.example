# Steam Idle Bot configuration via environment variables
# Copy to .env and fill in your values. Do NOT commit the filled .env.

# Required credentials
USERNAME=your_steam_username
PASSWORD=your_steam_password

# Optional: Steam Web API key
STEAM_API_KEY=

# Optional: authenticated Steam browser cookies for community page scraping
# Use JSON, for example:
# STEAM_WEB_COOKIES={"steamLoginSecure":"...","sessionid":"...","steamCountry":"..."}
STEAM_WEB_COOKIES={}

# Game settings
# Accepts JSON list (recommended) or CSV list
GAME_APP_IDS=[570,730]
FILTER_TRADING_CARDS=true
FILTER_COMPLETED_CARD_DROPS=true
EXCLUDE_APP_IDS=[]
USE_OWNED_GAMES=true
MAX_GAMES_TO_IDLE=30
# Seconds between re-running the game-selection pipeline while idling (min 10)
REFRESH_INTERVAL_SECONDS=600

# Idling backend
# python: current steam.client backend
# steam_utility: delegates idling to ../steam-utility-multiplataform (or STEAM_UTILITY_PATH)
IDLING_BACKEND=python
STEAM_UTILITY_PATH=

# Logging
LOG_LEVEL=INFO

# Performance tuning
API_TIMEOUT=10
# Base delay (seconds) between Steam API calls. Auto-increases on HTTP 429.
# Raise it (e.g. 2.0) for very large libraries to avoid throttling.
RATE_LIMIT_DELAY=1.0

# Trading-card cache
ENABLE_CARD_CACHE=true
CARD_CACHE_PATH=.cache/trading_cards.json
CARD_CACHE_TTL_DAYS=30
# No-drop cache: games confirmed without remaining card drops are skipped on
# future runs (a finished game never regains drops). Gated by ENABLE_CARD_CACHE.
DROP_CACHE_PATH=.cache/no_drop_cards.json
DROP_CACHE_TTL_DAYS=90

# Browser cookie recovery: if the configured STEAM_WEB_COOKIES are not a valid
# community session (e.g. a store-only/expired token), pull fresh cookies from a
# browser you're logged into Steam with. Set the browser or leave "auto".
AUTO_BROWSER_COOKIES=true
BROWSER_COOKIES_BROWSER=auto

# Filtering controls
# Optional: cap number of card checks; keep commented to disable
# MAX_CHECKS=100
SKIP_FAILURES=false
